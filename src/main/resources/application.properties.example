spring.application.name=ziovpo

server.port=8443

server.ssl.enabled=true
server.ssl.key-store-type=PKCS12
server.ssl.key-store=classpath:keystore.p12
server.ssl.key-store-password=${KEYSTORE_PASSWORD}
server.ssl.key-alias=laba6_key

spring.datasource.url=jdbc:postgresql://${DB_HOST}:5432/${DB_NAME}
spring.datasource.username=${DB_USER}
spring.datasource.password=${DB_PASSWORD}
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.jdbc.time_zone=UTC
logging.level.org.hibernate.SQL=DEBUG
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=TRACE

logging.level.com.example.ziovpo.config=DEBUG
logging.level.com.example.ziovpo.license.controller=DEBUG

jwt.secret=${JWT_SECRET}
jwt.access.expiration=${JWT_ACCESS_EXPIRATION:900000}
jwt.refresh.expiration.days=${JWT_REFRESH_DAYS:30}

app.admin.username=${ADMIN_USERNAME:admin}
app.admin.password=${ADMIN_PASSWORD}
app.admin.email=${ADMIN_EMAIL:admin@test.com}

signature.key-store-path=${SIGNATURE_KEYSTORE_PATH:classpath:keystore.p12}
signature.key-store-type=${SIGNATURE_KEYSTORE_TYPE:PKCS12}
signature.key-store-password=${KEYSTORE_PASSWORD}
signature.key-alias=${SIGNATURE_KEY_ALIAS:laba6_key}
signature.key-password=${SIGNATURE_KEY_PASSWORD:${KEYSTORE_PASSWORD}}
signature.algorithm=${SIGNATURE_ALGORITHM:SHA256withRSA}
