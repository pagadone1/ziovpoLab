{
  "info": {
    "name": "Lab2 Car Service — License",
    "description": "Лаба 2: лицензирование. Порядок: Login Admin → Create license → Login Client → Activate → Check → (опционально) Renew от Admin.\n\nПользователи: admin/Admin1234!, client/Client1234!\nHTTPS: отключите Verify SSL в Postman при localhost.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:8443" },
    { "key": "jwtToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "licenseCode", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.accessToken) pm.collectionVariables.set('jwtToken', j.accessToken);",
                  "if (j.refreshToken) pm.collectionVariables.set('refreshToken', j.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Client (owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.accessToken) pm.collectionVariables.set('jwtToken', j.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"client\",\n  \"password\": \"Client1234!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.accessToken) pm.collectionVariables.set('jwtToken', j.accessToken);",
                  "if (j.refreshToken) pm.collectionVariables.set('refreshToken', j.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "2. License (ADMIN create / renew)",
      "item": [
        {
          "name": "Create license (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.code) pm.collectionVariables.set('licenseCode', j.code);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{jwtToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"typeId\": 1,\n  \"ownerId\": 2,\n  \"deviceCount\": 3,\n  \"description\": \"Лицензия для клиента автосервиса\"\n}"
            },
            "url": "{{baseUrl}}/api/license"
          }
        },
        {
          "name": "Renew license (ADMIN only)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{jwtToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{licenseCode}}\"\n}"
            },
            "url": "{{baseUrl}}/api/license/renew"
          }
        }
      ]
    },
    {
      "name": "3. License (owner activate / check)",
      "item": [
        {
          "name": "Activate (owner only)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{jwtToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"activationKey\": \"{{licenseCode}}\",\n  \"deviceMac\": \"AA:BB:CC:DD:EE:FF\",\n  \"deviceName\": \"PC-Service-1\"\n}"
            },
            "url": "{{baseUrl}}/api/license/activate"
          }
        },
        {
          "name": "Check license (read ticket)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{jwtToken}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceMac\": \"AA:BB:CC:DD:EE:FF\"\n}"
            },
            "url": "{{baseUrl}}/api/license/check"
          }
        }
      ]
    }
  ]
}
