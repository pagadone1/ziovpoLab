{
  "info": {
    "name": "Lab3 — License + ЭЦП",
    "description": "Лаба 3: JCS + RSA подпись Ticket. Порядок: папка «0. Сценарий».\n\nSSL verification OFF. Environment Lab3 Local.\n\nadmin — из ADMIN_PASSWORD в .env (по умолчанию Admin1234! после bootstrap)\nclient / Client1234!\n\nФиксированные UUID в DemoIds.java",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:8443" },
    { "key": "adminToken", "value": "" },
    { "key": "clientToken", "value": "" },
    { "key": "licenseCode", "value": "" },
    { "key": "productId", "value": "22222222-2222-2222-2222-222222222201" },
    { "key": "typeStandardId", "value": "33333333-3333-3333-3333-333333333301" },
    { "key": "clientId", "value": "11111111-1111-1111-1111-111111111102" },
    { "key": "deviceMac", "value": "AA:BB:CC:DD:EE:FF" }
  ],
  "item": [
    {
      "name": "0. Сценарий лабы 3",
      "item": [
        {
          "name": "01 Login Admin",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "pm.collectionVariables.set('adminToken', j.accessToken);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin1234!\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "02 Create license",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "if (j.code) pm.collectionVariables.set('licenseCode', j.code);"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"typeId\": \"{{typeStandardId}}\",\n  \"ownerId\": \"{{clientId}}\",\n  \"deviceCount\": 3,\n  \"description\": \"Lab3 demo\"\n}" },
            "url": "{{baseUrl}}/api/licenses"
          }
        },
        {
          "name": "03 Renew (ADMIN, до activate)",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"activationKey\": \"{{licenseCode}}\"\n}" },
            "url": "{{baseUrl}}/api/licenses/renew"
          }
        },
        {
          "name": "04 Login Client",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "pm.collectionVariables.set('clientToken', j.accessToken);"
          ], "type": "text/javascript" }}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"client\",\n  \"password\": \"Client1234!\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "05 Activate → Ticket + signature",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('ticket+signature', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.ticket).to.be.an('object');",
            "  pm.expect(j.signature).to.be.a('string').and.not.empty;",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{clientToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"activationKey\": \"{{licenseCode}}\",\n  \"deviceMac\": \"{{deviceMac}}\",\n  \"deviceName\": \"PC-Lab3\"\n}" },
            "url": "{{baseUrl}}/api/licenses/activate"
          }
        },
        {
          "name": "06 Check → Ticket + signature",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json();",
            "pm.test('7 ticket fields', () => {",
            "  const t = j.ticket;",
            "  pm.expect(t.serverTime).to.exist;",
            "  pm.expect(t.ticketLifetimeSeconds).to.exist;",
            "  pm.expect(t.firstActivationDate).to.exist;",
            "  pm.expect(t.expirationDate).to.exist;",
            "  pm.expect(t.userId).to.exist;",
            "  pm.expect(t.deviceId).to.exist;",
            "  pm.expect(t).to.have.property('blocked');",
            "});"
          ], "type": "text/javascript" }}],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{clientToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"deviceMac\": \"{{deviceMac}}\",\n  \"productId\": \"{{productId}}\"\n}" },
            "url": "{{baseUrl}}/api/licenses/check"
          }
        }
      ]
    }
  ]
}
