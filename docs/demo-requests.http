### Лаба 2 — полный сценарий (сверху вниз)
@baseUrl = https://localhost:8443
@deviceMac = AA:BB:CC:DD:EE:FF

### 01 Admin login
# @name loginAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "Admin1234!"
}

@adminToken = {{loginAdmin.response.body.accessToken}}

### 02 Create license (ADMIN)
# @name createLicense
POST {{baseUrl}}/api/license
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "productId": 1,
  "typeId": 1,
  "ownerId": 2,
  "deviceCount": 3,
  "description": "Лаба 2"
}

@licenseCode = {{createLicense.response.body.code}}

### 03 Renew (до активации — демо продления)
POST {{baseUrl}}/api/license/renew
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "code": "{{licenseCode}}"
}

### 04 Client login (владелец)
# @name loginClient
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "client",
  "password": "Client1234!"
}

@clientToken = {{loginClient.response.body.accessToken}}

### 05 Activate → TicketResponse (7 полей + signature)
POST {{baseUrl}}/api/license/activate
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "activationKey": "{{licenseCode}}",
  "deviceMac": "{{deviceMac}}",
  "deviceName": "PC-Service-1"
}

### 06 Check → TicketResponse (БД не меняется)
POST {{baseUrl}}/api/license/check
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "deviceMac": "{{deviceMac}}"
}
