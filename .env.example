# PostgreSQL (docker-compose db service)
POSTGRES_DB=ziovpo_db
POSTGRES_USER=ziovpo_user
POSTGRES_PASSWORD=change_me

# Application database connection
DB_HOST=db
DB_NAME=ziovpo_db
DB_USER=ziovpo_user
DB_PASSWORD=change_me

# JWT
JWT_SECRET=change_me_min_32_characters
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_DAYS=30

# HTTPS / signature keystore (PKCS12)
KEYSTORE_PASSWORD=change_me
SIGNATURE_KEYSTORE_PATH=classpath:keystore.p12
SIGNATURE_KEYSTORE_TYPE=PKCS12
SIGNATURE_KEY_ALIAS=laba6_key
SIGNATURE_KEY_PASSWORD=
SIGNATURE_ALGORITHM=SHA256withRSA

# Bootstrap: admin + client (client всегда Client1234!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin1234!
ADMIN_EMAIL=admin@carservice.local
