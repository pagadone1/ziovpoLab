# Database (PostgreSQL)
DB_HOST=localhost
DB_NAME=itsupp_db
DB_USER=itsupp_user
DB_PASSWORD=change_me

# JWT
JWT_SECRET=change_me_min_32_characters
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_DAYS=30

# HTTPS keystore (PKCS12)
KEYSTORE_PASSWORD=change_me

# Bootstrap admin (created on first start if missing)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me
ADMIN_EMAIL=admin@example.com
