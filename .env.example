# PostgreSQL (создать: database/setup-labs-run.sql)
DB_USERNAME=photoprint_user
DB_PASSWORD=photoprint_pass

# JWT (минимум 32 символа, без дефисов в тестах CI)
JWT_SECRET=yourjwtsecretmin32charsforlocalrunok

# Пароль PKCS12 — тот же, что у src/main/resources/certs/keystore.p12
KEYSTORE_PASSWORD=changeit

# Bootstrap admin (создаётся при первом старте)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin1234!
